<UserControl x:Class="WindowsAuditTool.Views.LaunchView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:WindowsAuditTool.Converters"
             Background="{StaticResource BgBrush}">

    <UserControl.Resources>
        <converters:ElevationToBrushConverter x:Key="ElevBrush"/>
    </UserControl.Resources>

    <Grid>
        <Border Background="{StaticResource CardBrush}"
                CornerRadius="14"
                Padding="40"
                Margin="40"
                VerticalAlignment="Center"
                HorizontalAlignment="Center"
                MinWidth="480">
            <Border.Effect>
                <DropShadowEffect BlurRadius="16" ShadowDepth="2" Opacity="0.08" Color="Black"/>
            </Border.Effect>
            <StackPanel>
                <!-- Header -->
                <Border Background="{StaticResource AccentBrush}"
                        CornerRadius="10"
                        Padding="24,20"
                        Margin="0,0,0,24">
                    <StackPanel>
                        <TextBlock Text="Windows Audit Tool"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="Bold"/>
                        <TextBlock x:Name="VersionText"
                                   Text="GUI Wrapper v1.4.2.0"
                                   Foreground="White"
                                   Opacity="0.8"
                                   FontSize="13"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Update banner (shown when a newer version is available) -->
                <Border x:Name="UpdateBanner"
                        CornerRadius="8"
                        Padding="14,12"
                        Margin="0,0,0,16"
                        Visibility="Collapsed"
                        Background="#1A0078D4">
                    <DockPanel>
                        <Button x:Name="UpdateButton"
                                Content="Update &amp; Restart"
                                Style="{StaticResource SecondaryButton}"
                                DockPanel.Dock="Right"
                                Click="UpdateButton_Click"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock x:Name="UpdateText"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="#0078D4"/>
                            <TextBlock x:Name="UpdateSubText"
                                       FontSize="11"
                                       Foreground="{StaticResource MutedBrush}"/>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- Elevation status -->
                <Border x:Name="ElevationBanner"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse x:Name="ElevDot" Width="10" Height="10" Margin="0,0,10,0"/>
                        <TextBlock x:Name="ElevText" FontSize="13"/>
                    </StackPanel>
                </Border>

                <!-- Elevation button (shown when not elevated) -->
                <Button x:Name="ElevateButton"
                        Content="Restart as Administrator"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,0,20"
                        Visibility="Collapsed"
                        Click="ElevateButton_Click"/>

                <!-- Customer name -->
                <TextBlock Text="Customer Name"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="CustomerNameBox"
                         FontSize="14"
                         Padding="10,8"
                         Margin="0,0,0,20"/>

                <!-- Script status -->
                <Border x:Name="ScriptStatusBorder"
                        CornerRadius="8"
                        Padding="12,10"
                        Margin="0,0,0,24">
                    <DockPanel>
                        <Button x:Name="DownloadScriptButton"
                                Content="Download"
                                Style="{StaticResource SecondaryButton}"
                                DockPanel.Dock="Right"
                                Visibility="Collapsed"
                                Click="DownloadScriptButton_Click"/>
                        <TextBlock x:Name="ScriptStatusText"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>
                    </DockPanel>
                </Border>

                <!-- Export directory -->
                <TextBlock x:Name="ExportDirLabel"
                           FontSize="11"
                           Foreground="{StaticResource MutedBrush}"
                           Margin="0,0,0,6"
                           TextWrapping="Wrap"/>

                <!-- Config file indicator -->
                <TextBlock x:Name="ConfigIndicator"
                           Foreground="{StaticResource MutedBrush}"
                           FontSize="11"
                           Margin="0,0,0,20"
                           Visibility="Collapsed"/>

                <!-- Run button -->
                <Button x:Name="RunButton"
                        Content="Run Audit"
                        Style="{StaticResource PrimaryButton}"
                        HorizontalAlignment="Center"
                        FontSize="16"
                        Padding="48,14"
                        Click="RunButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
