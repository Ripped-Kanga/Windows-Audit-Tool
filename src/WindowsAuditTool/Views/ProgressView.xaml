<UserControl x:Class="WindowsAuditTool.Views.ProgressView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <Button x:Name="CancelButton"
                    Content="Cancel"
                    Style="{StaticResource SecondaryButton}"
                    DockPanel.Dock="Right"
                    Click="CancelButton_Click"/>
            <TextBlock Text="Running Audit..."
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       VerticalAlignment="Center"/>
        </DockPanel>

        <!-- Progress bar -->
        <Grid Grid.Row="1" Margin="0,0,0,8">
            <ProgressBar x:Name="ProgressBar"
                         Height="12"
                         Minimum="0"
                         Maximum="13"
                         Value="0"
                         Foreground="{StaticResource AccentBrush}"
                         Background="{StaticResource BorderBrush}">
                <ProgressBar.Template>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border CornerRadius="6" Background="{TemplateBinding Background}" BorderThickness="0">
                            <Border x:Name="PART_Track">
                                <Border x:Name="PART_Indicator"
                                        CornerRadius="6"
                                        Background="{TemplateBinding Foreground}"
                                        HorizontalAlignment="Left"/>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </ProgressBar.Template>
            </ProgressBar>
        </Grid>

        <!-- Step title -->
        <DockPanel Grid.Row="2" Margin="0,0,0,16">
            <TextBlock x:Name="StepCounter"
                       Text="0/13"
                       FontSize="13"
                       FontWeight="Bold"
                       Foreground="{StaticResource AccentBrush}"
                       DockPanel.Dock="Right"/>
            <TextBlock x:Name="StepTitle"
                       Text="Starting..."
                       FontSize="14"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource TextBrush}"
                       TextTrimming="CharacterEllipsis"/>
        </DockPanel>

        <!-- Scrolling log -->
        <Border Grid.Row="3"
                Background="{StaticResource CardBrush}"
                CornerRadius="10"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="1"
                Padding="0">
            <ScrollViewer x:Name="LogScroller"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled">
                <ItemsControl x:Name="LogItems">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Text="{Binding Text}"
                                       Foreground="{Binding Brush}"
                                       FontFamily="Consolas"
                                       FontSize="12"
                                       Padding="12,2"
                                       TextWrapping="Wrap"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Border>

        <!-- Bottom status -->
        <TextBlock x:Name="StatusText"
                   Grid.Row="4"
                   Margin="0,12,0,0"
                   FontSize="12"
                   Foreground="{StaticResource MutedBrush}"/>
    </Grid>
</UserControl>
