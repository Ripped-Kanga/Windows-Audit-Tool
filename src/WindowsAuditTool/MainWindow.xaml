<Window x:Class="WindowsAuditTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:WindowsAuditTool.Views"
        Title="Windows Audit Tool"
        Icon="pack://application:,,,/app.ico"
        Width="1000"
        Height="700"
        MinWidth="700"
        MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgBrush}">

    <Grid>
        <!-- Launch View (pre-audit) -->
        <views:LaunchView x:Name="LaunchView" Visibility="Visible"/>

        <!-- Progress View (during audit) -->
        <views:ProgressView x:Name="ProgressView" Visibility="Collapsed"/>

        <!-- Report View (post-audit) -->
        <views:ReportView x:Name="ReportView" Visibility="Collapsed"/>
    </Grid>
</Window>
